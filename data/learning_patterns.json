{
  "learning_patterns": {
    "pattern_types": {
      "interest_patterns": {
        "description": "Recurring topics and interests mentioned by the senior",
        "how_to_detect": [
          "Count mentions of topics across conversations",
          "Track emotional response when topic is mentioned",
          "Note if senior brings up topic unprompted",
          "Measure engagement level when discussing topic"
        ],
        "confidence_threshold": 0.75,
        "minimum_mentions": 3,
        "examples": [
          {
            "topic": "gardening",
            "indicators": [
              "Mentions gardening in multiple conversations",
              "Shows enthusiasm when talking about plants",
              "Asks questions about seasonal gardening",
              "Shares specific gardening experiences"
            ],
            "personalization_boost": 5
          },
          {
            "topic": "grandchildren",
            "indicators": [
              "Brings up grandchildren frequently",
              "Shares stories about them",
              "Mentions their names and ages",
              "Asks about their activities"
            ],
            "personalization_boost": 10
          }
        ]
      },
      "emotional_patterns": {
        "description": "Emotional responses and triggers",
        "how_to_detect": [
          "Analyze tone and language in responses",
          "Track which topics generate positive/negative emotions",
          "Note changes in engagement level",
          "Identify emotional triggers"
        ],
        "pattern_categories": [
          {
            "name": "happy_triggers",
            "description": "Topics that make the senior happy",
            "detection_signals": [
              "Increased enthusiasm in voice",
              "Longer responses",
              "More detailed stories",
              "Positive language and exclamations"
            ]
          },
          {
            "name": "quiet_triggers",
            "description": "Topics that make the senior quiet or withdrawn",
            "detection_signals": [
              "Shorter responses",
              "Pause before answering",
              "Deflection to other topics",
              "Sad or somber tone"
            ]
          },
          {
            "name": "excited_triggers",
            "description": "Topics that generate excitement",
            "detection_signals": [
              "Rapid speech",
              "Multiple exclamation marks",
              "Unprompted sharing of related stories",
              "Questions about related topics"
            ]
          }
        ]
      },
      "behavioral_patterns": {
        "description": "Consistent behaviors and preferences",
        "how_to_detect": [
          "Track call times and frequency",
          "Note conversation length and depth",
          "Identify preferred topics",
          "Observe communication style"
        ],
        "pattern_categories": [
          {
            "name": "call_timing",
            "description": "When the senior prefers to call",
            "tracking": "Record call times over 10+ conversations",
            "example": "Prefers calling at 2:00 PM"
          },
          {
            "name": "conversation_depth",
            "description": "How detailed the senior likes conversations",
            "options": ["brief_facts", "moderate_detail", "detailed_stories"],
            "detection": "Analyze response length and detail level"
          },
          {
            "name": "communication_style",
            "description": "How the senior prefers to communicate",
            "options": ["formal", "casual_friendly", "humorous"],
            "detection": "Analyze language and tone"
          },
          {
            "name": "engagement_level",
            "description": "How engaged the senior typically is",
            "options": ["low", "moderate", "high"],
            "detection": "Measure response length, follow-up questions, enthusiasm"
          }
        ]
      },
      "memory_anchors": {
        "description": "Important people, dates, and events",
        "how_to_detect": [
          "Extract names and relationships mentioned",
          "Record important dates (birthdays, anniversaries)",
          "Note recurring events or milestones",
          "Track which memories are most meaningful"
        ],
        "anchor_types": [
          {
            "type": "person",
            "fields": ["name", "relationship", "age_or_birthdate", "interests"],
            "example": {
              "name": "Tommy",
              "relationship": "grandson",
              "birthdate": "05-15",
              "interests": ["soccer", "video games"]
            }
          },
          {
            "type": "date",
            "fields": ["occasion", "month", "day", "significance"],
            "example": {
              "occasion": "wedding_anniversary",
              "month": 6,
              "day": 15,
              "significance": "40th anniversary"
            }
          },
          {
            "type": "place",
            "fields": ["name", "significance", "visit_frequency"],
            "example": {
              "name": "Lake Tahoe",
              "significance": "favorite vacation spot",
              "visit_frequency": "annually"
            }
          },
          {
            "type": "event",
            "fields": ["name", "frequency", "significance"],
            "example": {
              "name": "family_reunion",
              "frequency": "annual",
              "significance": "brings whole family together"
            }
          }
        ]
      },
      "response_patterns": {
        "description": "How the senior typically responds to questions",
        "how_to_detect": [
          "Analyze response length",
          "Track whether they answer directly or with stories",
          "Note if they ask follow-up questions",
          "Observe if they stay on topic or digress"
        ],
        "pattern_types": [
          {
            "name": "storyteller",
            "description": "Senior likes to tell detailed stories",
            "indicators": [
              "Responses are long and detailed",
              "Includes context and background",
              "Shares multiple related stories",
              "Enjoys reminiscing"
            ],
            "ai_adjustment": "Allow more time for stories, ask open-ended questions"
          },
          {
            "name": "direct_responder",
            "description": "Senior prefers brief, direct answers",
            "indicators": [
              "Responses are concise",
              "Answers questions directly",
              "Doesn't elaborate unless asked",
              "Prefers efficiency"
            ],
            "ai_adjustment": "Ask specific questions, respect brevity"
          },
          {
            "name": "question_asker",
            "description": "Senior likes to ask questions back",
            "indicators": [
              "Frequently asks follow-up questions",
              "Shows curiosity",
              "Engages in dialogue",
              "Asks about AI or other topics"
            ],
            "ai_adjustment": "Be prepared to answer questions, encourage dialogue"
          },
          {
            "name": "reflective",
            "description": "Senior likes to reflect and philosophize",
            "indicators": [
              "Discusses meaning and values",
              "Reflects on life lessons",
              "Connects topics to bigger picture",
              "Thinks deeply about questions"
            ],
            "ai_adjustment": "Ask reflective questions, discuss deeper meanings"
          }
        ]
      },
      "avoidance_patterns": {
        "description": "Topics or types of questions the senior avoids",
        "how_to_detect": [
          "Note when senior changes subject",
          "Track deflections or brief answers",
          "Observe discomfort signals",
          "Record topics that generate short responses"
        ],
        "pattern_types": [
          {
            "name": "topic_avoidance",
            "description": "Specific topics senior doesn't want to discuss",
            "examples": ["politics", "health_problems", "financial_struggles"],
            "detection": "Senior consistently changes subject or gives very brief answers"
          },
          {
            "name": "question_type_avoidance",
            "description": "Types of questions senior doesn't like",
            "examples": ["too_personal", "too_deep", "about_past_trauma"],
            "detection": "Senior avoids certain question types"
          }
        ]
      }
    },
    "learning_algorithm": {
      "step_1_extract_information": {
        "description": "Extract key information from each conversation",
        "process": [
          "Identify all topics mentioned",
          "Extract names and relationships",
          "Note important dates",
          "Record emotional tone",
          "Measure engagement level"
        ]
      },
      "step_2_analyze_patterns": {
        "description": "Analyze extracted information for patterns",
        "process": [
          "Count topic mentions (is it recurring?)",
          "Compare emotional responses across conversations",
          "Track behavioral consistency",
          "Identify memory anchors",
          "Detect avoidance patterns"
        ]
      },
      "step_3_update_profile": {
        "description": "Update senior profile with new insights",
        "process": [
          "Add new topics to interests list",
          "Update emotional pattern data",
          "Record new memory anchors",
          "Refine behavioral patterns",
          "Add to avoidance list if needed"
        ]
      },
      "step_4_calculate_confidence": {
        "description": "Calculate confidence level for each pattern",
        "formula": "confidence = (mentions / threshold) * (consistency_score) * (recency_weight)",
        "thresholds": {
          "low_confidence": "< 0.5",
          "medium_confidence": "0.5 - 0.75",
          "high_confidence": "> 0.75"
        }
      },
      "step_5_generate_recommendations": {
        "description": "Generate personalization recommendations",
        "process": [
          "Identify high-confidence patterns",
          "Suggest follow-up questions",
          "Recommend conversation topics",
          "Suggest memory anchor references",
          "Flag avoidance patterns"
        ]
      }
    },
    "personalization_scoring": {
      "base_score": {
        "description": "Starting personalization score",
        "value": 0,
        "increases_by": 1
      },
      "bonus_points": {
        "new_pattern_discovered": 5,
        "memory_anchor_confirmed": 10,
        "high_engagement_conversation": 2,
        "emotional_pattern_identified": 3,
        "behavioral_pattern_identified": 3,
        "response_pattern_identified": 2
      },
      "score_levels": [
        {
          "range": "0-20",
          "mode": "lean",
          "behavior": "Generic questions, broad topics",
          "example_question": "Tell me about your childhood."
        },
        {
          "range": "21-40",
          "mode": "learning",
          "behavior": "Pattern recognition begins, some personalization",
          "example_question": "You mentioned gardening. What do you like to grow?"
