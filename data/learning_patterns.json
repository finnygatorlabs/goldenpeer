        {
          "range": "41-60",
          "mode": "adaptive",
          "behavior": "Contextual follow-ups, moderate personalization",
          "example_question": "How's your garden coming along this spring?"
        },
        {
          "range": "61-80",
          "mode": "smart",
          "behavior": "Deep personalization, predictive questions",
          "example_question": "I know you love gardening. What new vegetables are you thinking about this year?"
        },
        {
          "range": "81-100",
          "mode": "expert",
          "behavior": "Genuine friend relationship, anticipates needs",
          "example_question": "Spring is here! I know you love starting your garden. Ready to plant those tomatoes again?"
        }
      ]
    },
